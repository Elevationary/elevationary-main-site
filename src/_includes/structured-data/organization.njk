<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "{{ site.orgId }}",
  "name": "{{ site.name }}",
  "url": "{{ site.url }}",
  "logo": "{{ site.url }}{{ site.logo }}",
  "description": "Elevationary is an AI consultancy, an AI product company, and a team of AI experts sharing what we know. We install AI-native operating capacity in organizations. We build, run, and own a multi-agent AI system end-to-end. And we operate P4D3 — the executive alignment system for human, agent, and combined teams, built to deliver organizational outcomes.",
  "email": "james.szmak@elevationary.com",
  "areaServed": "Worldwide",
  "knowsAbout": [
    "Artificial Intelligence Strategy",
    "Autonomous AI Agents",
    "Enterprise AI Transformation",
    "Agentic Commerce",
    "Data Sovereignty",
    "P4D3 Framework",
    "Digital Workforce Automation"
  ],
  "sameAs": [
    {% for social in site.socials %}
    "{{ social }}"{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "founder": {
    "@type": "Person",
    "name": "{{ site.founder.name }}",
    "url": "{{ site.founder.url }}"
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "email": "james.szmak@elevationary.com",
      "availableLanguage": "English"
    },
    {
      "@type": "ContactPoint",
      "contactType": "sales",
      "email": "james.szmak@elevationary.com",
      "url": "{{ site.agentSiteUrl }}/rfp/",
      "availableLanguage": "English",
      "areaServed": "Worldwide"
    }
  ]
}
</script>
