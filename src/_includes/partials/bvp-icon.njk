{# Lucide icon partial — single source of truth for inline SVG icons.
   Per D1.4 I1 + I2: Lucide only, stroke-width 2.
   Usage: {{ bvp_icon('arrow-right', 16) }}
#}
{% macro bvp_icon(name, size) %}
{% set sz = size or 16 %}
{% if name == 'arrow-right' %}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ sz }}" height="{{ sz }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
{% endif %}
{% endmacro %}
