title: "Upgrade your subscription | Elevationary"
description: "Your current subscription does not include the edition you tried to open. Upgrade to access the full archive."
layout: base.njk
eleventyExcludeFromCollections: true
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "{{ site.url }}/upgrade/#page",
  "name": "Upgrade your subscription",
  "url": "{{ site.url }}/upgrade/",
  "description": "{{ description }}"
}
</script>

<article class="page-content">
  <h1>Upgrade for full access</h1>

  <p id="upgrade-context" class="lede">Your subscription does not include this edition.</p>

  <p>Choose a plan that covers the swimlanes and history you need:</p>

  <p>
    <a href="/subscribe/" class="cta-primary">See subscription plans →</a>
    <a href="/account/" class="cta-secondary">Manage your current subscription →</a>
  </p>

  <p class="muted">Need help? <a href="/contact/">Contact us</a>.</p>
</article>

<script>
  // Personalize the lede from the ?swimlane= and ?edition= query params the
  // Entitlement Worker passes on redirect. No tracking — purely client-side
  // adjustment to the visible copy. Treat params as TEXT only (textContent,
  // not innerHTML) so any URL-borne content is safely escaped.
  (function() {
    var params = new URLSearchParams(window.location.search);
    var swimlane = params.get("swimlane");
    var edition = params.get("edition");
    if (!swimlane && !edition) return;
    var ctx = document.getElementById("upgrade-context");
    if (!ctx) return;
    function humanSwimlane(s) {
      var parts = s.split("_");
      if (parts.length < 2) return s;
      var stream = parts.shift();
      var rest = parts.map(function(p) { return p.charAt(0).toUpperCase() + p.slice(1); }).join(" ");
      return stream.charAt(0).toUpperCase() + stream.slice(1) + " · " + rest;
    }
    var parts = [];
    if (swimlane) parts.push("the " + humanSwimlane(swimlane) + " swimlane");
    if (edition) parts.push("the edition dated " + edition);
    ctx.textContent = "Your subscription does not include " + parts.join(" or ") + ".";
  })();
</script>
