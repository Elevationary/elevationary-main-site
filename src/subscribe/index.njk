---
title: "Subscribe — Elevationary"
description: "Choose the tier that matches how far up the L1→L5 ladder your team operates."
layout: layouts/bvp-base.njk
---

{% from 'partials/bvp-hero.njk' import bvp_hero %}
{% from 'partials/bvp-tier-card.njk' import bvp_tier_card %}
{% from 'partials/bvp-footer.njk' import bvp_footer %}
{% from 'partials/bvp-signup-cta.njk' import bvp_signup_cta %}

{{ bvp_hero(
  'subscribe-landing',
  'Intelligence and solutions elevating businesses to AI speeds.',
  '',
  ''
) }}

<section class="el-tier-grid" aria-label="Subscription tiers">

  {{ bvp_tier_card({
    slug: 'individual',
    name: 'Individual',
    price: '$29/month',
    features: [
      'One swimlane of weekly intelligence — pick where your work lives.',
      'Every Monday move + Sunday diagnostic, written for L2→L3 progression.',
      'Full archive access for your swimlane, including historical editions.'
    ],
    ctaLabel: 'Subscribe — Individual',
    ctaHref: '#tier-individual'
  }) }}

  {{ bvp_tier_card({
    slug: 'functional_bundle',
    name: 'Functional Bundle',
    price: '$69/month',
    features: [
      'Three connected swimlanes for cross-functional leaders.',
      'Pre-built bundles for Revenue, Operations, Growth, Mission, or Impact.',
      'Move your team from L2 documented to L3 systematized across three lanes at once.'
    ],
    ctaLabel: 'Subscribe — Functional Bundle',
    ctaHref: '#tier-functional-bundle'
  }) }}

  {{ bvp_tier_card({
    slug: 'all_access',
    name: 'All-Access',
    price: '$149/month',
    features: [
      'Every swimlane. Every edition. Every Monday move.',
      'Share with up to five teammates — the way L4 supervision actually works.',
      'Quarterly compilation of the patterns we keep returning to in team operations.'
    ],
    ctaLabel: 'Subscribe — All-Access',
    ctaHref: '#tier-all-access'
  }) }}

</section>

<section class="el-home__section">
  <h2 class="el-home__section-title">What you get on day one.</h2>
  <p class="el-home__lede">
    The next edition lands in your inbox within seven days. The archive opens immediately
    for the tier you choose. Cancel anytime &mdash; we keep the dunning logic short and the
    cancellation flow shorter.
  </p>
</section>

{% set footerCta %}
  {{ bvp_signup_cta('footer-anchored', 'Subscribe to Elevationary', '#tier-individual') }}
{% endset %}

{{ bvp_footer('full', footerCta) }}
