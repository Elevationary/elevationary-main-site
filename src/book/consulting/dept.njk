---
pagination:
  data: consulting_depts.depts
  size: 1
  alias: dept
permalink: "/book/consulting/{{ dept.slug }}/index.html"
eleventyComputed:
  title: "AI Strategy Consultation for {{ dept.name }} — Elevationary"
  description: "Working-session consulting on agentic AI deployment for {{ dept.name }} leadership. Four duration tiers from introductory to enterprise."
layout: layouts/bvp-base.njk
---

{% from 'partials/consulting-anatomy.njk' import consulting_anatomy %}

<section class="el-consulting el-consulting--dept">
  <header class="el-consulting__header">
    <h1 class="el-consulting__title">{{ dept.name }} consulting</h1>
    <div class="el-consulting__lede" data-hook="consulting-dept-context">
      {% if dept.context and dept.context != '__PLACEHOLDER_MARKETING_AUTHORED__' %}<p>{{ dept.context }}</p>{% else %}<p class="el-consulting__placeholder">{{ dept.name }} consulting context landing here.</p>{% endif %}
    </div>
    <p class="el-consulting__cta-top"><a href="/book/consulting/30-minute/" class="el-consulting__cta" data-hook="consulting-cta-top" data-action="book-30">Start with a 30-minute readiness session &rarr;</a></p>
  </header>

  {{ consulting_anatomy(dept.whoItsFor, dept.keyBenefits, dept.whatYouGet, null, consulting_depts.durations) }}

  <p class="el-consulting__cta-bottom"><a href="/answers/{{ dept.slug }}/" class="el-consulting__cta-secondary" data-hook="consulting-cta-bottom" data-action="answers">Read {{ dept.name }} answers first &rarr;</a></p>
</section>

{# Service JSON-LD for this dept page. The dept page is NOT an Offer
   surface (it's a qualifier/router); the 4 duration pages carry Offers. #}
{% set service_name = "AI Strategy Consultation for " + dept.name %}
{% set service_description = "Working-session consulting on agentic AI deployment for " + dept.name + " leadership." %}
{% set service_url = site.url + "/book/consulting/" + dept.slug + "/" %}
{% include 'structured-data/service-consulting.njk' %}
